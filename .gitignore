cat > .gitignore <<'EOF'
# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
.venv/
venv/
env/

# Environment variables
.env
.env.*

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/

# Test/cache files
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Streamlit
.streamlit/secrets.toml

# Data outputs
data/processed/
data/raw/
outputs/
reports/generated/
EOF